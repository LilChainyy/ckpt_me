DATABASE_URL="postgresql://user:password@host:5432/ckpt?sslmode=require"
GITHUB_ID="your-github-oauth-app-id"
GITHUB_SECRET="your-github-oauth-app-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret"

# Set to "true" to serve mock/demo data instead of using the database.
# Only for local development demos. Never set in production.
# NEXT_PUBLIC_DEMO_MODE="true"

# GitHub webhook integration (Phase 5)
# GITHUB_WEBHOOK_SECRET="your-webhook-secret"
# GITHUB_APP_TOKEN="your-github-app-token"
