# =============================================================================
# Production Environment Variables for apps/web
# Copy this file and fill in real values before deploying.
# =============================================================================

# --- Database (required) ---
# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host:5432/ckpt?sslmode=require"

# --- NextAuth (required) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Canonical URL of the deployment (Vercel sets this automatically)
# NEXTAUTH_URL="https://your-domain.vercel.app"

# --- GitHub OAuth (optional — needed for login) ---
GITHUB_ID=""
GITHUB_SECRET=""

# --- GitHub App / Webhook (optional — needed for PR comments) ---
GITHUB_WEBHOOK_SECRET=""
GITHUB_APP_TOKEN=""

# --- Feature flags ---
# Must be "false" in production. Never enable demo mode in prod.
NEXT_PUBLIC_DEMO_MODE="false"
